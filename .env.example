# Required
TELEGRAM_BOT_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Redis (at least one pair required)
REDIS_URL=
# or
UPSTASH_REDIS_URL=

# External API Keys
PERPLEXITY_API_KEY=
OMDB_API_KEY=
WATCHMODE_API_KEY=

# Optional Feature Flags (default: true)
ENABLE_PERPLEXITY=true
ENABLE_TRAILERS=true
ENABLE_EXPLANATIONS=true

# Worker
WORKER_THREADS=8
PORT=5000
